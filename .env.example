# LeadClaw environment variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key for AI features (draft-followup, summarize, pipeline)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional: Override the AI model used for drafting/summaries
# Default: claude-haiku-4-5-20251001
# LEADCLAW_MODEL=claude-haiku-4-5-20251001

# Optional: Override the database path
# Default: data/leads.db (relative to project root)
# LEADCLAW_DB=/path/to/your/leads.db

# --- Web dashboard (Flask) ---

# Required in production: random secret key for Flask sessions
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LEADCLAW_SECRET_KEY=change-me-to-a-random-secret

# Server bind settings (default: localhost:7432)
PORT=7432
HOST=127.0.0.1

# --- Email verification (SMTP) ---
# Leave SMTP_HOST unset to print verification links to stdout (local dev mode)
# Resend (preferred — set this and SMTP vars are ignored)
RESEND_API_KEY=re_your_key_here

# SMTP fallback (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# Public base URL used in verification emails
APP_URL=https://app.leadclaw.io
